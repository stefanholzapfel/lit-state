{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2021",
    "lib": ["dom", "es2021"],
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "rootDir": "src",
